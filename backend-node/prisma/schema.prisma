// Prisma schema for STUDLYF HR Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String              @id @default(uuid())
  fullName             String
  email                String              @unique
  hashedPassword       String
  companyName          String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  profilePhoto         String?
  phone                String?
  address              String?
  city                 String?
  state                String?
  country              String?
  designation          String?
  companyAddress       String?
  companyPhone         String?
  companyEmail         String?
  companyWebsite       String?
  defaultFont          String              @default("Times New Roman")
  defaultBorderColor   String              @default("#2D136F")
  defaultLineSpacing   String              @default("1.25")
  defaultLetterSpacing String              @default("0px")
  branding             CompanyBranding?
  documents            Document[]
  recentEdits          RecentEdit[]
  applications         Application[]
  screeningQuestions   ScreeningQuestion[]
  meetings             Meeting[]
  messages             Message[]

  @@map("users")
}

model CompanyBranding {
  id             String     @id @default(uuid())
  userId         String     @unique
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String     @default("#2D136F")
  secondaryColor String     @default("#5D22D8")
  letterheadUrl  String?
  signatureUrl   String?
  sealUrl        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  documents      Document[]

  @@map("company_branding")
}

model Template {
  id           String     @id @default(uuid())
  name         String
  type         String
  baseJSON     Json
  isReusable   Boolean    @default(false)
  thumbnailUrl String?
  isPremium    Boolean    @default(false)
  layoutType   String?
  createdAt    DateTime   @default(now())
  documents    Document[]

  @@map("templates")
}

model Document {
  id               String           @id @default(uuid())
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String
  title            String?
  status           String           @default("draft")
  lastOpenedAt     DateTime         @default(now()) @map("last_opened_at")
  exportCount      Int              @default(0) @map("export_count")
  templateId       String?          @map("template_id")
  template         Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  candidateDetails Json
  contentJSON      Json
  brandingId       String?
  branding         CompanyBranding? @relation(fields: [brandingId], references: [id], onDelete: SetNull)
  exportUrl        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  recentEdits      RecentEdit[]
  emailLogs        EmailLog[]

  @@index([userId])
  @@map("documents")
}

model RecentEdit {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lastEditedAt DateTime @default(now())

  @@index([userId])
  @@map("recent_edits")
}

model EmailLog {
  id             String   @id @default(uuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipientEmail String
  status         String
  sentAt         DateTime @default(now())

  @@map("email_logs")
}

model Student {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  bio               String?
  skills            String[]
  avatarUrl         String?
  linkedinUrl       String?
  portfolioUrl      String?
  githubUsername    String?            @unique
  githubId          String?            @unique
  githubAccessToken String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  githubStats       GitHubStats?
  projects          HackathonProject[]
  applications      Application[]
  messages          Message[]
}

model GitHubStats {
  id           String   @id @default(uuid())
  studentId    String   @unique
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topLanguages Json     @default("{}")
  totalRepos   Int      @default(0)
  totalStars   Int      @default(0)
  totalCommits Int      @default(0)
  totalForks   Int      @default(0)
  lastSyncedAt DateTime @default(now())
}

model HackathonProject {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  hackathonName String?
  tags          String[]
  juryRating    Float?
  repoUrl       String?
  demoUrl       String?
  imageUrl      String?
  createdAt     DateTime @default(now())

  @@index([studentId])
}

model Application {
  id                 String              @id @default(uuid())
  hrId               String
  hr                 User                @relation(fields: [hrId], references: [id], onDelete: Cascade)
  studentId          String
  student            Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status             String              @default("invited")
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  screeningResponses ScreeningResponse[]
  meeting            Meeting?

  @@unique([hrId, studentId])
  @@index([hrId])
  @@index([studentId])
}

model ScreeningQuestion {
  id                 String              @id @default(uuid())
  hrId               String
  hr                 User                @relation(fields: [hrId], references: [id], onDelete: Cascade)
  question           String
  isTemplate         Boolean             @default(false)
  createdAt          DateTime            @default(now())
  screeningResponses ScreeningResponse[]

  @@index([hrId])
}

model ScreeningResponse {
  id            String            @id @default(uuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionId    String
  question      ScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer        String?
  submittedAt   DateTime          @default(now())
}

model Meeting {
  id                 String       @id @default(uuid())
  hrId               String
  hr                 User         @relation(fields: [hrId], references: [id], onDelete: Cascade)
  applicationId      String?      @unique
  application        Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  title              String
  description        String?
  scheduledAt        DateTime?
  calendlyEventUrl   String?
  calendlyEventId    String?
  calendlyInviteeUri String?
  status             String       @default("scheduled")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([hrId])
}

model Message {
  id        String   @id @default(uuid())
  hrId      String
  hr        User     @relation(fields: [hrId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content   String
  isRead    Boolean  @default(false)
  sentAt    DateTime @default(now())

  @@index([hrId, studentId])
}
