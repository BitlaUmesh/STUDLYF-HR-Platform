// This is your Prisma schema file for STUDLYF HR Platform
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// HR SIDE MODELS (migrated from Python FastAPI)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  hashedPassword String
  companyName    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Personal profile
  profilePhoto String?
  phone        String?
  address      String?
  city         String?
  state        String?
  country      String?
  designation  String?

  // Company info
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  companyWebsite  String?

  // Document preferences
  defaultFont          String @default("Times New Roman")
  defaultBorderColor   String @default("#2D136F")
  defaultLineSpacing   String @default("1.25")
  defaultLetterSpacing String @default("0px")

  // Relations
  branding          CompanyBranding?
  documents         Document[]
  recentEdits       RecentEdit[]
  applications      Application[]
  screeningQuestions ScreeningQuestion[]
  meetings          Meeting[]
  sentMessages      Message[]           @relation("HRSentMessages")

  @@map("users")
}

model CompanyBranding {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logoUrl       String?
  primaryColor  String   @default("#2D136F")
  secondaryColor String  @default("#5D22D8")
  letterheadUrl String?
  signatureUrl  String?
  sealUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documents     Document[]

  @@map("company_branding")
}

model Template {
  id           String   @id @default(uuid())
  name         String
  type         String   // "OFFER_LETTER" | "JOINING_LETTER"
  baseJSON     Json
  isReusable   Boolean  @default(false)
  thumbnailUrl String?
  isPremium    Boolean  @default(false)
  layoutType   String?
  createdAt    DateTime @default(now())

  documents Document[]

  @@map("templates")
}

model Document {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // "OFFER_LETTER" | "JOINING_LETTER"
  title      String?
  status     String   @default("draft") // "draft" | "completed" | "exported" | "archived"

  lastOpenedAt DateTime @default(now()) @map("last_opened_at")
  exportCount  Int      @default(0) @map("export_count")

  templateId       String?   @map("template_id")
  template         Template?  @relation(fields: [templateId], references: [id])
  candidateDetails Json
  contentJSON      Json
  brandingId       String?
  branding         CompanyBranding? @relation(fields: [brandingId], references: [id])
  exportUrl        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recentEdits RecentEdit[]
  emailLogs   EmailLog[]

  @@index([userId])
  @@map("documents")
}

model RecentEdit {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lastEditedAt DateTime @default(now())

  @@index([userId])
  @@map("recent_edits")
}

model EmailLog {
  id             String   @id @default(uuid())
  documentId     String
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  recipientEmail String
  status         String   // "SENT" | "FAILED" | "PENDING"
  sentAt         DateTime @default(now())

  @@map("email_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// STUDENT MODELS (new)
// ─────────────────────────────────────────────────────────────────────────────

model Student {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  bio          String?
  skills       String[] // ["AIML", "Frontend", "Python"]
  avatarUrl    String?
  linkedinUrl  String?
  portfolioUrl String?

  // GitHub OAuth
  githubUsername    String? @unique
  githubId          String? @unique  // GitHub's numeric user ID
  githubAccessToken String? // stored encrypted — used for API calls

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  githubStats   GitHubStats?
  projects      HackathonProject[]
  applications  Application[]
  receivedMessages Message[] @relation("StudentReceivedMessages")
}

model GitHubStats {
  id            String   @id @default(uuid())
  studentId     String   @unique
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Stored as JSON: { "TypeScript": 45.2, "Python": 30.1, "Rust": 15.0 } (percentages)
  topLanguages  Json     @default("{}")
  totalRepos    Int      @default(0)
  totalStars    Int      @default(0)
  totalCommits  Int      @default(0)
  totalForks    Int      @default(0)

  lastSyncedAt  DateTime @default(now())
}

model HackathonProject {
  id            String   @id @default(uuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  name          String
  description   String?
  hackathonName String?
  tags          String[] // ["AIML", "Web3", "IoT", "HealthTech"]
  juryRating    Float?   // 0.0 – 10.0 scale from jury
  repoUrl       String?
  demoUrl       String?
  imageUrl      String?

  createdAt DateTime @default(now())

  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// HIRING PIPELINE MODELS (new)
// ─────────────────────────────────────────────────────────────────────────────

model Application {
  id        String  @id @default(uuid())
  hrId      String
  hr        User    @relation(fields: [hrId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Status flow: invited → reviewing → questions_sent → offered | rejected
  status    String  @default("invited")
  notes     String? // internal HR notes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  responses ScreeningResponse[]
  meeting   Meeting?

  @@unique([hrId, studentId]) // HR can only have one application per student
  @@index([hrId])
  @@index([studentId])
}

model ScreeningQuestion {
  id         String  @id @default(uuid())
  hrId       String
  hr         User    @relation(fields: [hrId], references: [id], onDelete: Cascade)
  question   String
  isTemplate Boolean @default(false) // save for reuse across multiple applications

  createdAt DateTime @default(now())

  responses ScreeningResponse[]

  @@index([hrId])
}

model ScreeningResponse {
  id            String            @id @default(uuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionId    String
  question      ScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer        String?
  submittedAt   DateTime          @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// MEETINGS MODEL — Calendly Integration (new)
// ─────────────────────────────────────────────────────────────────────────────

model Meeting {
  id            String  @id @default(uuid())
  hrId          String
  hr            User    @relation(fields: [hrId], references: [id], onDelete: Cascade)
  applicationId String? @unique
  application   Application? @relation(fields: [applicationId], references: [id])

  title             String
  description       String?
  scheduledAt       DateTime?

  // Calendly data
  calendlyEventUrl  String?  // booking link sent to student
  calendlyEventId   String?  // Calendly's internal event URI (for webhook matching)
  calendlyInviteeUri String? // Calendly's invitee URI after booking confirmed

  // "scheduled" | "confirmed" | "completed" | "cancelled"
  status        String   @default("scheduled")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hrId])
}

// ─────────────────────────────────────────────────────────────────────────────
// MESSAGING MODEL (new)
// ─────────────────────────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(uuid())
  hrId       String
  hr         User     @relation("HRSentMessages", fields: [hrId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student  @relation("StudentReceivedMessages", fields: [studentId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  sentAt     DateTime @default(now())

  @@index([hrId, studentId])
}
